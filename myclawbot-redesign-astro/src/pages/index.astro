---
import "../styles/main.css";
---
<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
  <title>Open-ClawBot — OpenClaw в Telegram за 1 минуту</title>
  <meta name="description" content="Премиальный запуск OpenClaw в Telegram за 1 минуту. Один тариф — 3 890 ₽/мес." />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Onest:wght@400;500;600;700;800&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
  <meta name="theme-color" content="#000000" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="color-scheme" content="dark" />
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
</head>
<body>
  <div class="bg-noise"></div>

  <header class="header">
    <div class="container nav">
      <a class="brand" href="/"><img class="brand-logo" src="/assets/logo-bot.png" alt="logo"></a>
      <div class="row small-gap">
        <a class="btn header-btn header-btn--primary" href="/login/"><img class="header-btn__icon" src="/assets/icons/login/user-filled.svg" alt="">Войти</a>
      </div>
    </div>
  </header>

  <main class="container">
    <section class="hero">
      <p class="kicker">OpenClaw в Telegram · без SSH и Docker</p>
      <h1>Твой личный AI-ассистент<br>за 1 минуту</h1>
      <p class="lead">Один тариф <b>3 890 ₽/мес</b>. Включены VPS, установка, обновления и поддержка на русском.</p>
      <div class="cta-row">
        <a class="btn btn-primary" href="#price">Запустить за 3 890 ₽</a>
        <a class="btn btn-ghost" href="#capabilities">Что умеет OpenClaw</a>
      </div>
      <div class="stats">
        <div><strong>1 мин</strong><span>до запуска</span></div>
        <div><strong>1 тариф</strong><span>всё включено</span></div>
        <div><strong>24/7</strong><span>бот в онлайне</span></div>
      </div>
    </section>

    <section class="panel setup">
      <h2>Выбор модели на старте</h2>
      <div class="model-tabs" role="tablist" aria-label="Выбор модели">
        <button class="model-tab active" data-model="claude" aria-selected="true"><img src="./assets/icons/claude.svg" alt="Claude"> Claude Opus 4.5</button>
        <button class="model-tab" data-model="gpt" aria-selected="false"><img src="./assets/icons/chatgpt.png" alt="GPT"> GPT-5.2</button>
        <button class="model-tab" data-model="gemini" aria-selected="false"><img src="./assets/icons/gemini.png" alt="Gemini"> Gemini 3 Flash</button>
        <button class="model-tab" data-model="deepseek" aria-selected="false"><img src="https://cdn.simpleicons.org/deepseek/6ea8ff" alt="DeepSeek"> DeepSeek V3</button>
      </div>
      <button class="more-ai-btn" id="moreAiBtn" type="button">Больше ИИ / другие нейросети</button>
      <div class="more-ai-panel" id="moreAiPanel" aria-hidden="true">
        <button class="ai-option" data-model="mistral"><img src="https://cdn.simpleicons.org/mistral/feb36f" alt="Mistral"> Mistral</button>
        <button class="ai-option" data-model="llama"><img src="https://cdn.simpleicons.org/meta/7ec6ff" alt="Llama"> Llama</button>
        <button class="ai-option" data-model="cohere"><img src="https://cdn.simpleicons.org/cohere/b08cff" alt="Cohere"> Cohere</button>
        <button class="ai-option" data-model="qwen"><img src="https://cdn.simpleicons.org/alibabacloud/ffb66f" alt="Qwen"> Qwen</button>
        <button class="ai-option" data-model="grok"><img src="https://cdn.simpleicons.org/x/f8f8f8" alt="Grok"> Grok (xAI)</button>
      </div>
      <div class="model-info" id="modelInfo">
        <h3>Claude Opus 4.5</h3>
        <p>Максимум качества для сложных задач, кода и анализа.</p>
      </div>
      <div class="channel-row">
        <button class="channel active" id="tgOpen"><img src="./assets/icons/telegram.png" alt="Telegram"> Telegram</button>
      </div>

      <a class="btn btn-google full" href="#">Войти через Google</a>
      <p class="form-note">Вход нужен для запуска бота.</p>
    </section>

    <div class="modal-backdrop" id="tgModal" aria-hidden="true">
      <div class="modal" role="dialog" aria-modal="true" aria-labelledby="tgTitle">
        <button class="modal-close" id="tgClose" aria-label="Закрыть">×</button>
        <h3 id="tgTitle">Подключить Telegram</h3>
        <p class="modal-sub">Как получить токен бота?</p>
        <ol>
          <li>Откройте <b>@BotFather</b> в Telegram.</li>
          <li>Введите <code>/newbot</code> и создайте бота.</li>
          <li>Скопируйте токен и вставьте его ниже.</li>
        </ol>
        <label for="botToken">Введите токен бота</label>
        <input id="botToken" type="text" placeholder="1234567890:ABCdefGHI_jklMNOpqrSTUVwx" />
        <button class="btn btn-primary full" id="saveToken">Сохранить ✓</button>
      </div>
    </div>

    <section id="capabilities" class="section">
      <div class="skills-board">
        <h2>Что умеет OpenClaw?</h2>
        <p class="subhead">Один ассистент — тысячи задач</p>

        <div class="marquee-rows">
          <div class="marquee-row left">
            <div class="marquee-track">
              <article class="chip chip-grad"><img src="./assets/icons/caps/write.svg" alt=""><span>Писать длинные документы</span></article>
              <article class="chip chip-plain"><img src="./assets/icons/caps/bell.svg" alt=""><span>Напоминать о встречах</span></article>
              <article class="chip chip-dashed"><img src="./assets/icons/caps/note.svg" alt=""><span>Вести заметки со встреч</span></article>
              <article class="chip chip-grad"><img src="./assets/icons/caps/write.svg" alt=""><span>Писать длинные документы</span></article>
              <article class="chip chip-plain"><img src="./assets/icons/caps/bell.svg" alt=""><span>Напоминать о встречах</span></article>
              <article class="chip chip-dashed"><img src="./assets/icons/caps/note.svg" alt=""><span>Вести заметки со встреч</span></article>
            </div>
          </div>

          <div class="marquee-row right">
            <div class="marquee-track">
              <article class="chip"><img src="./assets/icons/caps/sync.svg" alt=""><span>Синхронизировать данные</span></article>
              <article class="chip"><img src="./assets/icons/caps/box.svg" alt=""><span>Анализировать характеристики товаров</span></article>
              <article class="chip"><img src="./assets/icons/caps/chart.svg" alt=""><span>Вести проекты и задачи</span></article>
              <article class="chip"><img src="./assets/icons/caps/sync.svg" alt=""><span>Синхронизировать данные</span></article>
              <article class="chip"><img src="./assets/icons/caps/box.svg" alt=""><span>Анализировать характеристики товаров</span></article>
              <article class="chip"><img src="./assets/icons/caps/chart.svg" alt=""><span>Вести проекты и задачи</span></article>
            </div>
          </div>

          <div class="marquee-row left">
            <div class="marquee-track">
              <article class="chip"><img src="./assets/icons/caps/filter.svg" alt=""><span>Фильтровать и приоритизировать лиды</span></article>
              <article class="chip"><img src="./assets/icons/caps/users.svg" alt=""><span>Делать саммари стендапов</span></article>
              <article class="chip"><img src="./assets/icons/caps/note.svg" alt=""><span>Отправлять сводки по встречам</span></article>
              <article class="chip"><img src="./assets/icons/caps/filter.svg" alt=""><span>Фильтровать и приоритизировать лиды</span></article>
              <article class="chip"><img src="./assets/icons/caps/users.svg" alt=""><span>Делать саммари стендапов</span></article>
              <article class="chip"><img src="./assets/icons/caps/note.svg" alt=""><span>Отправлять сводки по встречам</span></article>
            </div>
          </div>

          <div class="marquee-row right">
            <div class="marquee-track">
              <article class="chip"><img src="./assets/icons/caps/write.svg" alt=""><span>Писать вакансии и JD</span></article>
              <article class="chip"><img src="./assets/icons/caps/chart.svg" alt=""><span>Делать отчёты по метрикам</span></article>
              <article class="chip"><img src="./assets/icons/caps/sync.svg" alt=""><span>Сводить данные из разных сервисов</span></article>
              <article class="chip"><img src="./assets/icons/caps/write.svg" alt=""><span>Писать вакансии и JD</span></article>
              <article class="chip"><img src="./assets/icons/caps/chart.svg" alt=""><span>Делать отчёты по метрикам</span></article>
              <article class="chip"><img src="./assets/icons/caps/sync.svg" alt=""><span>Сводить данные из разных сервисов</span></article>
            </div>
          </div>

          <div class="marquee-row left">
            <div class="marquee-track">
              <article class="chip"><img src="./assets/icons/caps/bell.svg" alt=""><span>Контролировать дедлайны</span></article>
              <article class="chip"><img src="./assets/icons/caps/box.svg" alt=""><span>Сравнивать товары и офферы</span></article>
              <article class="chip"><img src="./assets/icons/caps/users.svg" alt=""><span>Готовить саммари стендапов</span></article>
              <article class="chip"><img src="./assets/icons/caps/bell.svg" alt=""><span>Контролировать дедлайны</span></article>
              <article class="chip"><img src="./assets/icons/caps/box.svg" alt=""><span>Сравнивать товары и офферы</span></article>
              <article class="chip"><img src="./assets/icons/caps/users.svg" alt=""><span>Готовить саммари стендапов</span></article>
            </div>
          </div>
        </div>

        <a class="kb-link" href="/guides/">База знаний →</a>
        <p class="board-note">P.S. Вы можете добавлять любые сценарии использования на естественном языке</p>
      </div>
    </section>

    <section id="price" class="section">
      <div class="price-card panel">
        <p class="muted">Один тариф</p>
        <p class="price">3 890 ₽ <span>/ месяц</span></p>
        <ul>
          <li>Выделенный VPS-сервер</li>
          <li>Установленный OpenClaw</li>
          <li>Выбор AI-модели при запуске</li>
          <li>1 000 ₽ бонус на AI-запросы</li>
          <li>Обновления и поддержка</li>
        </ul>
        <a class="btn btn-primary full" href="#">Оплатить и запустить</a>
      </div>
    </section>

    <section class="section subscription-includes">
      <h2>Что входит в подписку?</h2>
      <div class="includes-grid">
        <article class="include-card">
          <h3><span class="include-icon"><img src="./assets/icons/caps/box.svg" alt=""></span>Выделенный VPS-сервер</h3>
          <p>Ваш персональный сервер, не shared-хостинг. Не нужно покупать VPS отдельно — всё включено в подписку.</p>
        </article>
        <article class="include-card">
          <h3><span class="include-icon"><img src="./assets/icons/caps/sync.svg" alt=""></span>Установленный OpenClaw</h3>
          <p>Последняя версия OpenClaw, правильно настроенная и готовая к работе. Подключение к Telegram за 1 минуту.</p>
        </article>
        <article class="include-card">
          <h3><span class="include-icon"><img src="./assets/icons/caps/chart.svg" alt=""></span>Бонус 1 000 ₽ на AI-запросы</h3>
          <p>Хватит на 2–3 недели обычного использования. Тратится на обращения к моделям Claude, ChatGPT или Gemini.</p>
        </article>
        <article class="include-card">
          <h3><span class="include-icon"><img src="./assets/icons/caps/users.svg" alt=""></span>AI-агент поддержки</h3>
          <p>Встроенный AI-агент ответит на вопросы и поможет разобраться с настройкой бота на русском языке.</p>
        </article>
        <article class="include-card">
          <h3><span class="include-icon"><img src="./assets/icons/caps/bell.svg" alt=""></span>Автоматические обновления</h3>
          <p>OpenClaw обновляется еженедельно. Мы ставим новые версии автоматически — вам не нужно ничего делать.</p>
        </article>
        <article class="include-card">
          <h3><span class="include-icon"><img src="./assets/icons/caps/filter.svg" alt=""></span>Выбор AI-модели</h3>
          <p>Claude Opus, ChatGPT (GPT-4o), Gemini, DeepSeek — переключайте модели в любой момент прямо в боте.</p>
        </article>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-grid">
      <div>
        <a class="brand" href="/"><img class="brand-logo" src="/assets/logo-bot.png" alt="logo"></a>
        <p>OpenClaw в Telegram за 1 минуту.</p>
      </div>
      <div>
        <h4>Продукт</h4>
        <a href="#capabilities">Возможности</a>
        <a href="/guides/">База знаний</a>
        <a href="#price">Тариф</a>
      </div>
      <div>
        <h4>Документы</h4>
        <a href="/privacy-policy/">Политика конфиденциальности</a>
        <a href="/terms-of-service/">Условия использования</a>
        <a href="/cookie-policy/">Политика cookies</a>
        <a href="/refund-policy/">Возвраты</a>
        <a href="/contact/">Контакты</a>
      </div>
    </div>
    <div class="container copy">© 2026 Open-ClawBot</div>
  </footer>

  <script>
    const info = {
      claude: {title: 'Claude Opus 4.5', text: 'Максимум качества для сложных задач, кода и анализа.'},
      gpt: {title: 'GPT-5.2', text: 'Универсальный быстрый режим для ежедневной работы.'},
      gemini: {title: 'Gemini 3 Flash', text: 'Отлично подходит для мультимодальных сценариев.'},
      deepseek: {title: 'DeepSeek V3', text: 'Сильная модель для кода и рабочих задач по цене ниже топовых.'},
      mistral: {title: 'Mistral', text: 'Быстрая и стабильная модель для повседневных задач и чатов.'},
      llama: {title: 'Llama', text: 'Сбалансированная open-weight модель для широкого спектра задач.'},
      cohere: {title: 'Cohere', text: 'Хороша для корпоративных сценариев и структурированных ответов.'},
      qwen: {title: 'Qwen', text: 'Мощная универсальная линейка моделей от Alibaba Cloud.'},
      grok: {title: 'Grok (xAI)', text: 'Модель xAI для живых диалогов и быстрого поиска инсайтов.'}
    };

    const tabs = document.querySelectorAll('.model-tab');
    const box = document.getElementById('modelInfo');
    const moreAiBtn = document.getElementById('moreAiBtn');
    const moreAiPanel = document.getElementById('moreAiPanel');
    const aiOptions = document.querySelectorAll('.ai-option');

    function renderModel(key) {
      const m = info[key];
      if (!m) return;
      box.innerHTML = `<h3>${m.title}</h3><p>${m.text}</p>`;
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected','false'); });
        tab.classList.add('active');
        tab.setAttribute('aria-selected','true');
        renderModel(tab.dataset.model);
      });
    });

    moreAiBtn.addEventListener('click', () => {
      const open = moreAiPanel.classList.toggle('open');
      moreAiPanel.setAttribute('aria-hidden', open ? 'false' : 'true');
    });

    aiOptions.forEach(btn => {
      btn.addEventListener('click', () => {
        tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected','false'); });
        renderModel(btn.dataset.model);
      });
    });

    const tgModal = document.getElementById('tgModal');
    const tgOpen = document.getElementById('tgOpen');
    const tgClose = document.getElementById('tgClose');
    const tokenInput = document.getElementById('botToken');
    const saveToken = document.getElementById('saveToken');

    tgOpen.addEventListener('click', () => {
      tgModal.classList.add('open');
      tgModal.setAttribute('aria-hidden', 'false');
      setTimeout(() => tokenInput.focus(), 60);
    });

    function closeModal() {
      tgModal.classList.remove('open');
      tgModal.setAttribute('aria-hidden', 'true');
    }

    tgClose.addEventListener('click', closeModal);
    tgModal.addEventListener('click', (e) => {
      if (e.target === tgModal) closeModal();
    });

    saveToken.addEventListener('click', () => {
      const value = tokenInput.value.trim();
      if (!value) return;
      localStorage.setItem('myclawbot_tg_token', value);
      saveToken.textContent = 'Сохранено ✓';
      setTimeout(closeModal, 500);
    });

    const saved = localStorage.getItem('myclawbot_tg_token');
    if (saved) tokenInput.value = saved;
  </script>
  <script is:inline src="/visit-tracker.js"></script>
</body>
</html>