  </main>

  <footer class="footer">
    <div class="container footer-grid">
      <div>
        <a class="brand" href="/"><img class="brand-logo" src="/assets/logo-bot.png" alt="logo"></a>
        <p>OpenClaw в Telegram за 1 минуту.</p>
      </div>
      <div>
        <h4>Продукт</h4>
        <a href="#capabilities">Возможности</a>
        <a href="/guides/">База знаний</a>
        <a href="#price">Тариф</a>
      </div>
      <div>
        <h4>Документы</h4>
        <a href="/privacy-policy/">Политика конфиденциальности</a>
        <a href="/terms-of-service/">Условия использования</a>
        <a href="/cookie-policy/">Политика cookies</a>
        <a href="/refund-policy/">Возвраты</a>
        <a href="/contact/">Контакты</a>
      </div>
    </div>
    <div class="container copy">© 2026 Open-ClawBot</div>
  </footer>

  <script>
    const info = {
      claude: {title: 'Anthropic Claude', text: 'Максимум качества для сложных задач, кода и анализа.'},
      gpt: {title: 'OpenAI ChatGPT', text: 'Универсальный быстрый режим для ежедневной работы.'},
      gemini: {title: 'Google Gemini', text: 'Отлично подходит для мультимодальных сценариев.'},
      deepseek: {title: 'DeepSeek', text: 'Сильная модель для кода и рабочих задач по цене ниже топовых.'},
      mistral: {title: 'Mistral AI', text: 'Быстрая и стабильная модель для повседневных задач и чатов.'},
      llama: {title: 'Meta Llama', text: 'Сбалансированная open-weight модель для широкого спектра задач.'},
      cohere: {title: 'Cohere', text: 'Хороша для корпоративных сценариев и структурированных ответов.'},
      qwen: {title: 'Alibaba Qwen', text: 'Мощная универсальная линейка моделей от Alibaba Cloud.'},
      grok: {title: 'xAI Grok', text: 'Модель xAI для живых диалогов и быстрого поиска инсайтов.'}
    };

    const providerModels = {
      claude: ['Claude 4.5 Opus', 'Claude 4.5 Sonnet', 'Claude 4.1 Sonnet'],
      gpt: ['GPT-5.2', 'GPT-5.1', 'GPT-4.1'],
      gemini: ['Gemini 2.5 Pro', 'Gemini 2.5 Flash', 'Gemini 2.0 Flash'],
      deepseek: ['DeepSeek R1', 'DeepSeek V3', 'DeepSeek Coder V2'],
      mistral: ['Mistral Large 2', 'Mistral Nemo', 'Codestral 2'],
      llama: ['Llama 4', 'Llama 3.3 70B', 'Llama 3.1 405B'],
      cohere: ['Command R+ 08-2024', 'Command R', 'Command R7B'],
      qwen: ['Qwen 2.5 Max', 'Qwen 2.5 72B', 'Qwen 2.5 Coder'],
      grok: ['Grok 3', 'Grok 2', 'Grok Vision']
    };

    const tabs = document.querySelectorAll('.model-tab');
    const box = document.getElementById('modelInfo');
    const moreAiBtn = document.getElementById('moreAiBtn');
    const moreAiPanel = document.getElementById('moreAiPanel');
    const aiOptions = document.querySelectorAll('.ai-option');
    const modelPillsEl = document.getElementById('modelPills');

    // PixelBlast-style animated background for first screen
    const ditherCanvas = document.getElementById('heroDither');
    if (ditherCanvas) {
      const ctx = ditherCanvas.getContext('2d', { alpha: true });
      if (ctx) {
        let w = 0, h = 0, cell = 8;
        let cols = 0, rows = 0;

        function resizeBlast() {
          const rect = ditherCanvas.getBoundingClientRect();
          const dpr = Math.min(window.devicePixelRatio || 1, 2);
          w = Math.max(1, Math.floor(rect.width * dpr));
          h = Math.max(1, Math.floor(rect.height * dpr));
          ditherCanvas.width = w;
          ditherCanvas.height = h;
          cell = Math.max(6, Math.floor(Math.min(w, h) / 95));
          cols = Math.ceil(w / cell);
          rows = Math.ceil(h / cell);
        }

        function draw(ts) {
          const t = ts * 0.001;
          ctx.clearRect(0, 0, w, h);

          const bg = ctx.createLinearGradient(0, 0, w, h);
          bg.addColorStop(0, '#090204');
          bg.addColorStop(0.5, '#140306');
          bg.addColorStop(1, '#080203');
          ctx.fillStyle = bg;
          ctx.fillRect(0, 0, w, h);

          const cx = cols * 0.5;
          const cy = rows * 0.52;
          const pulse = (Math.sin(t * 1.1) + 1) * 0.5;

          for (let y = 0; y < rows; y++) {
            for (let x = 0; x < cols; x++) {
              const dx = x - cx;
              const dy = y - cy;
              const dist = Math.sqrt(dx * dx + dy * dy);
              const ang = Math.atan2(dy, dx);
              const spiral = Math.sin(ang * 7.0 + dist * 0.42 - t * 2.6) * 0.5 + 0.5;
              const core = Math.sin(dist * 0.25 - t * 1.6) * 0.5 + 0.5;
              const fade = Math.exp(-dist * 0.06);
              const n = Math.sin((x * 0.18 + y * 0.16 + t * 0.7)) * 0.5 + 0.5;
              const v = (spiral * 0.62 + core * 0.2 + n * 0.18) * fade;

              if (v < 0.045) continue;

              const r = Math.floor(120 + 135 * v + 10 * pulse);
              const g = Math.floor(8 + 45 * v);
              const b = Math.floor(10 + 28 * v);
              const a = Math.min(0.85, 0.12 + v * 0.9);

              ctx.fillStyle = `rgba(${r},${g},${b},${a})`;
              const px = x * cell;
              const py = y * cell;
              const inset = v > 0.5 ? 0 : 1;
              ctx.fillRect(px + inset, py + inset, cell - inset, cell - inset);
            }
          }

          requestAnimationFrame(draw);
        }

        resizeBlast();
        window.addEventListener('resize', resizeBlast);
        requestAnimationFrame(draw);
      }
    }

    function renderModel(key) {
      const m = info[key];
      if (!m) return;
      const h = box.querySelector('h3');
      const p = box.querySelector('p');
      if (h) h.textContent = m.title;
      if (p) p.textContent = m.text;

      const models = providerModels[key] || [];
      modelPillsEl.innerHTML = models.map((name, i) =>
        `<button class="model-pill ${i === 0 ? 'active' : ''}" data-model="${key}" type="button">${name}</button>`
      ).join('');

      modelPillsEl.querySelectorAll('.model-pill').forEach(btn => {
        btn.addEventListener('click', () => {
          modelPillsEl.querySelectorAll('.model-pill').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
        });
      });
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected','false'); });
        aiOptions.forEach(a => a.classList.remove('active'));
        tab.classList.add('active');
        tab.setAttribute('aria-selected','true');
        renderModel(tab.dataset.model);
      });
    });

    moreAiBtn.addEventListener('click', () => {
      const open = moreAiPanel.classList.toggle('open');
      moreAiPanel.setAttribute('aria-hidden', open ? 'false' : 'true');
      if (open) moreAiBtn.style.display = 'none';
    });

    aiOptions.forEach(btn => {
      btn.addEventListener('click', () => {
        tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected','false'); });
        aiOptions.forEach(a => a.classList.remove('active'));
        btn.classList.add('active');
        renderModel(btn.dataset.model);
      });
    });

    // token amount selector (button presets)
    const tokenPills = document.querySelectorAll('.token-pill');
    tokenPills.forEach(pill => {
      pill.addEventListener('click', () => {
        tokenPills.forEach(p => p.classList.remove('active'));
        pill.classList.add('active');
      });
    });

    renderModel('claude');

    const tgModal = document.getElementById('tgModal');
    const tgOpen = document.getElementById('tgOpen');
    const tgClose = document.getElementById('tgClose');
    const tokenInput = document.getElementById('botToken');
    const saveToken = document.getElementById('saveToken');

    tgOpen.addEventListener('click', () => {
      tgModal.classList.add('open');
      tgModal.setAttribute('aria-hidden', 'false');
      setTimeout(() => tokenInput.focus(), 60);
    });

    function closeModal() {
      tgModal.classList.remove('open');
      tgModal.setAttribute('aria-hidden', 'true');
    }

    tgClose.addEventListener('click', closeModal);
    tgModal.addEventListener('click', (e) => {
      if (e.target === tgModal) closeModal();
    });

    saveToken.addEventListener('click', () => {
      const value = tokenInput.value.trim();
      if (!value) return;
      localStorage.setItem('myclawbot_tg_token', value);
      saveToken.textContent = 'Сохранено ✓';
      setTimeout(closeModal, 500);
    });

    const saved = localStorage.getItem('myclawbot_tg_token');
    if (saved) tokenInput.value = saved;
  </script>
  <script is:inline src="/visit-tracker.js"></script>
</body>
</html>