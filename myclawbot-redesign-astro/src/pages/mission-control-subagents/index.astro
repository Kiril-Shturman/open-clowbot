---
---

<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Центр миссий — Subagents</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=Press+Start+2P&display=swap" rel="stylesheet">
    <style>
      :root {
        --bg: #0b0d12;
        --panel: #11161f;
        --panel-2: #171d28;
        --line: rgba(255,255,255,.08);
        --text: #f5f7fb;
        --muted: #98a3b8;
        --danger: #ff5662;
        --danger-2: #ab1837;
        --ok: #63f59b;
        --warn: #ffcf57;
        --cyan: #70ddff;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        color: var(--text);
        font-family: 'IBM Plex Sans', system-ui, sans-serif;
        background:
          radial-gradient(circle at top left, rgba(255,86,98,.18), transparent 24%),
          radial-gradient(circle at top right, rgba(112,221,255,.12), transparent 20%),
          linear-gradient(180deg, #0b0d12 0%, #080a0f 100%);
      }
      .wrap { width: min(1440px, calc(100% - 28px)); margin: 0 auto; padding: 20px 0 40px; }
      .card, .topbar {
        background: linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));
        border: 1px solid var(--line);
        border-radius: 24px;
        box-shadow: 0 24px 80px rgba(0,0,0,.36);
      }
      .topbar {
        display: flex; justify-content: space-between; align-items: center; gap: 16px;
        padding: 16px 18px; margin-bottom: 16px;
      }
      .brand { display: flex; gap: 14px; align-items: center; }
      .mark {
        width: 54px; height: 54px; border-radius: 18px; display: grid; place-items: center;
        background: linear-gradient(135deg, var(--cyan), #17789b); color: #091118;
        font-family: 'Press Start 2P', monospace; font-size: 11px;
      }
      .eyebrow { font-size: 11px; letter-spacing: .08em; text-transform: uppercase; color: #9cecff; font-weight: 800; }
      h1 { margin: 6px 0 4px; font-size: clamp(26px, 4vw, 42px); line-height: .98; }
      .subtitle { margin: 0; color: var(--muted); max-width: 760px; }
      .actions { display: flex; gap: 10px; flex-wrap: wrap; }
      .btn {
        border: 1px solid rgba(255,255,255,.08); border-radius: 14px; padding: 12px 14px;
        background: rgba(255,255,255,.04); color: #fff; font-weight: 700; cursor: pointer;
      }
      .btn.primary { background: linear-gradient(135deg, var(--cyan), #17789b); color: #091118; border-color: transparent; }
      .btn.warn { background: linear-gradient(135deg, #ffcf57, #b27a08); color: #161103; border-color: transparent; }
      .hero-grid { display: grid; grid-template-columns: 1.15fr .85fr; gap: 16px; margin-bottom: 16px; }
      .card { padding: 18px; }
      .section-head { display: flex; justify-content: space-between; align-items: center; gap: 12px; margin-bottom: 14px; }
      .section-title { font-size: 20px; font-weight: 800; }
      .tag { display: inline-flex; padding: 6px 10px; border-radius: 999px; font-size: 12px; font-weight: 700; background: rgba(255,255,255,.06); }
      .tag.live { background: rgba(99,245,155,.14); color: #c8fbd9; }
      .tag.cyan { background: rgba(112,221,255,.14); color: #c7f2ff; }
      .tag.warn { background: rgba(255,207,87,.14); color: #ffe7a6; }
      .mission-title { font-size: clamp(28px, 4vw, 44px); font-weight: 800; line-height: .98; margin-bottom: 14px; }
      .stat-grid { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 12px; margin-bottom: 14px; }
      .stat { padding: 14px; border-radius: 18px; background: var(--panel-2); border: 1px solid rgba(255,255,255,.06); }
      .label { color: var(--muted); font-size: 13px; }
      .value { font-size: 26px; font-weight: 800; margin-top: 6px; }
      .panel { padding: 14px; border-radius: 18px; background: var(--panel-2); border: 1px solid rgba(255,255,255,.06); }
      .panel strong { display: block; margin-bottom: 6px; }
      .flow { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; margin-bottom: 16px; }
      .subagents { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; margin-bottom: 16px; }
      .agent { padding: 16px; border-radius: 20px; background: var(--panel-2); border: 1px solid rgba(255,255,255,.06); }
      .agent-name { font-size: 16px; font-weight: 800; }
      .agent-role { margin-top: 4px; color: var(--muted); font-size: 13px; }
      .agent-task { margin-top: 12px; font-size: 14px; line-height: 1.35; }
      .agent-status { margin-top: 10px; color: var(--muted); font-size: 12px; }
      .lower-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
      .list { display: grid; gap: 10px; }
      .item { padding: 14px; border-radius: 18px; background: var(--panel-2); border: 1px solid rgba(255,255,255,.06); }
      .item-title { font-size: 15px; font-weight: 700; }
      .item-meta { margin-top: 6px; color: var(--muted); font-size: 13px; line-height: 1.4; }
      .textarea, .select {
        width: 100%; min-height: 54px; border-radius: 14px; border: 1px solid rgba(255,255,255,.08);
        background: rgba(255,255,255,.04); color: #fff; padding: 12px 14px; font: inherit;
      }
      .textarea { min-height: 96px; resize: vertical; }
      .form { display: grid; gap: 10px; }
      .two { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
      @media (max-width: 1180px) {
        .hero-grid, .flow, .subagents, .lower-grid, .stat-grid, .two { grid-template-columns: 1fr; }
      }
      @media (max-width: 760px) {
        .wrap { width: min(100% - 18px, 1440px); }
        .topbar { flex-direction: column; align-items: stretch; }
        .actions { width: 100%; }
        .btn { width: 100%; }
      }
    </style>
  </head>
  <body>
    <main class="wrap">
      <section class="topbar">
        <div class="brand">
          <div class="mark">SA</div>
          <div>
            <div class="eyebrow">Subagent model</div>
            <h1>Центр миссий — через саб-агентов</h1>
            <p class="subtitle">Основная новая ветка. Один главный агент играет COO, а реальную работу отдает изолированным саб-агентам под конкретные задачи.</p>
          </div>
        </div>
        <div class="actions">
          <a class="btn" href="/mission-control/">Старая версия</a>
          <button class="btn" id="tickBtn">Шаг цикла</button>
          <button class="btn warn" id="blockerBtn">Смоделировать blocker</button>
          <button class="btn primary" id="startBtn">START</button>
        </div>
      </section>

      <section class="hero-grid">
        <article class="card">
          <div class="section-head"><div class="section-title">1. Главная миссия</div><span class="tag live" id="missionTag">COO active</span></div>
          <div class="mission-title" id="missionTitle">Собрать 10 кейсов использования OpenClaw для предпринимателей</div>
          <div class="stat-grid">
            <div class="stat"><div class="label">Commander</div><div class="value">COO</div></div>
            <div class="stat"><div class="label">Subagents</div><div class="value" id="subagentCount">3</div></div>
            <div class="stat"><div class="label">Активный шаг</div><div class="value" id="stepValue">1/3</div></div>
            <div class="stat"><div class="label">Статус</div><div class="value" id="statusValue">В работе</div></div>
          </div>
          <div class="panel"><strong>Что делает COO</strong><span id="cooLine">Принимает задачу, дробит её на шаги, спавнит саб-агентов и собирает их outputs в один итог.</span></div>
          <div class="panel" style="margin-top:12px;"><strong>Следующий шаг</strong><span id="nextStep">Запустить Research Subagent на сбор кейсов.</span></div>
        </article>

        <article class="card">
          <div class="section-head"><div class="section-title">2. Запуск миссии</div><span class="tag cyan">Founder input</span></div>
          <div class="form">
            <textarea class="textarea" id="missionInput">Собери 10 сильных кейсов использования OpenClaw для предпринимателей и упакуй их в понятные идеи для сайта и Reels.</textarea>
            <div class="two">
              <select class="select" id="missionType">
                <option>Контент</option>
                <option>Ресерч</option>
                <option>Продукт</option>
                <option>Продажи</option>
              </select>
              <select class="select" id="missionPriority">
                <option>Высокий приоритет</option>
                <option>Средний приоритет</option>
                <option>Низкий приоритет</option>
              </select>
            </div>
          </div>
          <div class="panel" style="margin-top:12px;"><strong>Как это работает</strong> Founder ставит задачу → COO превращает её в миссию → спавнит саб-агентов → собирает результат → решает следующий шаг.</div>
        </article>
      </section>

      <section class="card" style="margin-bottom:16px;">
        <div class="section-head"><div class="section-title">3. Как течёт работа</div><span class="tag">Простой контур</span></div>
        <div class="flow">
          <div class="panel"><strong>Founder</strong><span id="flowFounder">Даёт цель и приоритет.</span></div>
          <div class="panel"><strong>COO agent</strong><span id="flowCoo">Разбивает на шаги и выбирает, кого спавнить первым.</span></div>
          <div class="panel"><strong>Subagents</strong><span id="flowSubagents">Делают узкие задачи: research, content, build.</span></div>
        </div>
      </section>

      <article class="card" style="margin-bottom:16px;">
        <div class="section-head"><div class="section-title">4. Кто сейчас работает</div><span class="tag cyan">Execution layer</span></div>
        <div class="subagents" id="subagentsList"></div>
      </article>

      <section class="lower-grid">
        <article class="card">
          <div class="section-head"><div class="section-title">Что уже вернулось</div><span class="tag live">Artifacts</span></div>
          <div class="list" id="artifactsList"></div>
        </article>
        <article class="card">
          <div class="section-head"><div class="section-title">Проблемы</div><span class="tag">Blockers</span></div>
          <div class="list" id="blockersList"></div>
        </article>
        <article class="card">
          <div class="section-head"><div class="section-title">Лента COO</div><span class="tag cyan">Mission log</span></div>
          <div class="list" id="logList"></div>
        </article>
      </section>
    </main>

    <script>
      const STORAGE_KEY = 'mission-control-subagents-v1';
      const templates = {
        Контент: [
          { name: 'Research Subagent', role: 'Поиск и анализ', task: 'Собирает кейсы и паттерны', output: 'Список кейсов и инсайтов' },
          { name: 'Content Subagent', role: 'Контент и упаковка', task: 'Превращает кейсы в темы и hooks', output: 'Темы для сайта и Reels' },
          { name: 'Builder Subagent', role: 'Сборка результата', task: 'Упаковывает финальный артефакт', output: 'Структура страницы / финальный драфт' },
        ],
        Ресерч: [
          { name: 'Research Subagent', role: 'Поиск и анализ', task: 'Поднимает источники и сравнения', output: 'Таблица и summary' },
          { name: 'Synthesis Subagent', role: 'Синтез', task: 'Собирает выводы и паттерны', output: 'Ключевые выводы' },
          { name: 'Packager Subagent', role: 'Упаковка', task: 'Собирает итоговый отчёт', output: 'Готовый документ' },
        ],
        Продукт: [
          { name: 'Research Subagent', role: 'Ресерч', task: 'Собирает входные требования', output: 'Список требований' },
          { name: 'Builder Subagent', role: 'Разработка', task: 'Готовит реализацию / прототип', output: 'MVP / код' },
          { name: 'QA Subagent', role: 'Проверка', task: 'Проверяет результат и слабые места', output: 'Список доработок' },
        ],
        Продажи: [
          { name: 'Lead Subagent', role: 'Лиды', task: 'Ищет подходящих лидов', output: 'Lead list' },
          { name: 'Offer Subagent', role: 'Оффер', task: 'Готовит оффер и сообщения', output: 'Outreach pack' },
          { name: 'Closer Subagent', role: 'Финализация', task: 'Собирает итог и next actions', output: 'Готовый sales handoff' },
        ],
      };

      const defaultState = {
        missionTitle: 'Собрать 10 кейсов использования OpenClaw для предпринимателей',
        missionType: 'Контент',
        missionPriority: 'Высокий приоритет',
        status: 'В работе',
        step: 1,
        cooLine: 'Принимает задачу, дробит её на шаги, спавнит саб-агентов и собирает их outputs в один итог.',
        nextStep: 'Запустить Research Subagent на сбор кейсов.',
        agents: templates['Контент'].map((a, i) => ({ ...a, status: i === 0 ? 'Активен' : 'В очереди' })),
        artifacts: [],
        blockers: [],
        log: ['COO готов принять новую миссию и распределить первый цикл задач.'],
      };

      let state = loadState();

      function loadState() {
        try {
          const raw = localStorage.getItem(STORAGE_KEY);
          return raw ? JSON.parse(raw) : structuredClone(defaultState);
        } catch {
          return structuredClone(defaultState);
        }
      }
      function saveState() { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); }
      function $(id) { return document.getElementById(id); }
      function pushLog(text) { state.log.unshift(text); state.log = state.log.slice(0, 10); }

      function render() {
        $('missionTitle').textContent = state.missionTitle;
        $('statusValue').textContent = state.status;
        $('stepValue').textContent = `${Math.min(state.step, state.agents.length)}/${state.agents.length}`;
        $('cooLine').textContent = state.cooLine;
        $('nextStep').textContent = state.nextStep;
        $('subagentCount').textContent = String(state.agents.length);
        $('missionTag').textContent = state.status === 'Готово' ? 'Mission complete' : 'COO active';
        $('flowFounder').textContent = `${state.missionType} • ${state.missionPriority}`;
        $('flowCoo').textContent = state.cooLine;
        $('flowSubagents').textContent = state.agents.map((a) => a.name).join(', ');

        $('subagentsList').innerHTML = state.agents.map((agent) => `
          <div class="agent">
            <div class="agent-name">${agent.name}</div>
            <div class="agent-role">${agent.role}</div>
            <div class="agent-task">${agent.task}</div>
            <div class="agent-status">Статус: ${agent.status}</div>
          </div>
        `).join('');

        $('artifactsList').innerHTML = state.artifacts.length
          ? state.artifacts.map((a) => `<div class="item"><div class="item-title">${a.title}</div><div class="item-meta">${a.body}</div></div>`).join('')
          : '<div class="item"><div class="item-title">Пока пусто</div><div class="item-meta">Артефакты появятся, когда саб-агенты начнут возвращать результаты.</div></div>';

        $('blockersList').innerHTML = state.blockers.length
          ? state.blockers.map((b) => `<div class="item"><div class="item-title">${b.title}</div><div class="item-meta">${b.body}</div></div>`).join('')
          : '<div class="item"><div class="item-title">Пока нет blocker-ов</div><div class="item-meta">COO пока держит миссию без эскалаций.</div></div>';

        $('logList').innerHTML = state.log.map((line) => `<div class="item"><div class="item-title">${line}</div></div>`).join('');
        saveState();
      }

      function startMission() {
        const type = $('missionType').value;
        const priority = $('missionPriority').value;
        const title = $('missionInput').value.trim() || 'Новая миссия';
        state.missionTitle = title;
        state.missionType = type;
        state.missionPriority = priority;
        state.status = 'В работе';
        state.step = 1;
        state.cooLine = `COO принял миссию типа «${type}», разбил её на ${templates[type].length} шага и активировал первого саб-агента.`;
        state.nextStep = `Дождаться результата от ${templates[type][0].name}.`;
        state.agents = templates[type].map((a, i) => ({ ...a, status: i === 0 ? 'Активен' : 'В очереди' }));
        state.artifacts = [];
        state.blockers = [];
        state.log = [`Founder поставил миссию: ${title}`, `COO активировал ${templates[type][0].name}.`];
        render();
      }

      function tickCycle() {
        if (state.status === 'Готово') return;
        const activeIndex = state.agents.findIndex((a) => a.status === 'Активен');
        if (activeIndex === -1) return;
        const active = state.agents[activeIndex];
        active.status = 'Завершил';
        state.artifacts.unshift({ title: `${active.name} вернул результат`, body: active.output });
        pushLog(`${active.name} завершил шаг и вернул артефакт COO.`);

        const next = state.agents[activeIndex + 1];
        if (next) {
          next.status = 'Активен';
          state.step = activeIndex + 2;
          state.nextStep = `Дождаться результата от ${next.name}.`;
          state.cooLine = `COO принял артефакт от ${active.name} и передал эстафету ${next.name}.`;
          pushLog(`COO активировал ${next.name}.`);
        } else {
          state.status = 'Готово';
          state.step = state.agents.length;
          state.nextStep = 'Миссия завершена. Можно запускать следующую.';
          state.cooLine = 'COO собрал все артефакты и закрыл миссию.';
          pushLog('COO завершил миссию и собрал финальный итог.');
        }
        render();
      }

      function addBlocker() {
        const active = state.agents.find((a) => a.status === 'Активен');
        const who = active ? active.name : 'Unknown Subagent';
        state.blockers.unshift({ title: `${who}: blocker`, body: 'Нужен дополнительный контекст / входные данные для продолжения.' });
        state.blockers = state.blockers.slice(0, 5);
        state.cooLine = `COO получил blocker от ${who} и должен решить — уточнить задачу или перераспределить работу.`;
        state.nextStep = `Разобрать blocker от ${who} и дать новый приказ.`;
        pushLog(`${who} поднял blocker. COO ждёт решения.`);
        render();
      }

      $('startBtn').addEventListener('click', startMission);
      $('tickBtn').addEventListener('click', tickCycle);
      $('blockerBtn').addEventListener('click', addBlocker);
      render();
    </script>
  </body>
</html>
