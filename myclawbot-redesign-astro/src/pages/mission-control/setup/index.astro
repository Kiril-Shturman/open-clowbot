---
---

<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Собери команду — Центр миссий</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=Press+Start+2P&display=swap" rel="stylesheet">
    <style>
      :root {
        --bg: #0b0d12;
        --panel: #11161f;
        --panel-2: #171d28;
        --line: rgba(255,255,255,.08);
        --text: #f5f7fb;
        --muted: #98a3b8;
        --danger: #ff5662;
        --danger-2: #ab1837;
        --ok: #63f59b;
        --warn: #ffcf57;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        color: var(--text);
        font-family: 'IBM Plex Sans', system-ui, sans-serif;
        background:
          radial-gradient(circle at top left, rgba(255,86,98,.18), transparent 24%),
          radial-gradient(circle at top right, rgba(112,221,255,.12), transparent 20%),
          linear-gradient(180deg, #0b0d12 0%, #080a0f 100%);
      }
      .wrap { width: min(1200px, calc(100% - 28px)); margin: 0 auto; padding: 24px 0 40px; }
      .card {
        background: linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));
        border: 1px solid var(--line);
        border-radius: 24px;
        box-shadow: 0 24px 80px rgba(0,0,0,.36);
        padding: 20px;
      }
      .eyebrow { font-size: 11px; letter-spacing: .08em; text-transform: uppercase; color: #ff9ea7; font-weight: 800; }
      h1 { margin: 8px 0 6px; font-size: clamp(28px, 4vw, 48px); line-height: .98; }
      .subtitle { margin: 0; color: var(--muted); max-width: 760px; }
      .top-actions { margin-top: 18px; display: flex; gap: 10px; flex-wrap: wrap; }
      .btn {
        border: 1px solid rgba(255,255,255,.08); border-radius: 14px; padding: 12px 14px;
        background: rgba(255,255,255,.04); color: #fff; font-weight: 700; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; justify-content: center;
      }
      .btn.primary { background: linear-gradient(135deg, var(--danger), var(--danger-2)); border-color: transparent; }
      .btn.success { background: linear-gradient(135deg, #59d989, #18834f); border-color: transparent; }
      .grid { display: grid; grid-template-columns: 1.2fr .85fr; gap: 16px; margin-top: 16px; }
      .roles { display: grid; gap: 12px; }
      .role {
        display: grid; grid-template-columns: auto 1fr auto; gap: 12px; align-items: center;
        padding: 16px; border-radius: 18px; background: var(--panel-2); border: 1px solid rgba(255,255,255,.06);
      }
      .role input { width: 18px; height: 18px; }
      .role-name { font-size: 16px; font-weight: 800; }
      .role-desc { color: var(--muted); font-size: 13px; margin-top: 4px; }
      .tag { display: inline-flex; padding: 6px 10px; border-radius: 999px; font-size: 12px; font-weight: 700; background: rgba(255,255,255,.06); }
      .tag.ok { background: rgba(99,245,155,.14); color: #c8fbd9; }
      .summary { display: grid; gap: 12px; }
      .box {
        padding: 16px; border-radius: 18px; background: var(--panel-2); border: 1px solid rgba(255,255,255,.06);
      }
      .box h3 { margin: 0 0 10px; font-size: 16px; }
      .muted { color: var(--muted); font-size: 13px; line-height: 1.45; }
      .list { display: grid; gap: 8px; margin-top: 10px; }
      .list div { color: var(--text); font-size: 14px; }
      @media (max-width: 980px) { .grid { grid-template-columns: 1fr; } }
    </style>
  </head>
  <body>
    <main class="wrap">
      <section class="card">
        <div class="eyebrow">Шаг 1 из 2</div>
        <h1>Собери команду</h1>
        <p class="subtitle">Пока это экран подготовки. Здесь нужно выбрать состав команды перед запуском миссии. Следующий шаг после этого — подключить реальных ботов/агентов вместо демо-ролей и связать их с Mission Control.</p>
        <div class="top-actions">
          <a class="btn" href="/mission-control/">Назад</a>
          <button class="btn" id="selectAllBtn">Выбрать всех</button>
          <button class="btn primary" id="continueBtn">Продолжить</button>
        </div>
      </section>

      <section class="grid">
        <article class="card roles">
          <label class="role">
            <input type="checkbox" class="agent-check" value="Scout" checked>
            <div>
              <div class="role-name">Scout</div>
              <div class="role-desc">Ищет источники, конкурентов, каналы, лидов и сырой материал.</div>
            </div>
            <span class="tag ok">обязателен</span>
          </label>
          <label class="role">
            <input type="checkbox" class="agent-check" value="Analyst" checked>
            <div>
              <div class="role-name">Analyst</div>
              <div class="role-desc">Разбирает данные, выделяет паттерны, строит выводы и структуру.</div>
            </div>
            <span class="tag ok">обязателен</span>
          </label>
          <label class="role">
            <input type="checkbox" class="agent-check" value="Writer" checked>
            <div>
              <div class="role-name">Writer</div>
              <div class="role-desc">Пишет тексты, summaries, офферы, заголовки и драфты.</div>
            </div>
            <span class="tag ok">обязателен</span>
          </label>
          <label class="role">
            <input type="checkbox" class="agent-check" value="Operator" checked>
            <div>
              <div class="role-name">Operator</div>
              <div class="role-desc">Следит за прогрессом, check-in циклами, роутингом и статусами.</div>
            </div>
            <span class="tag ok">обязателен</span>
          </label>
          <label class="role">
            <input type="checkbox" class="agent-check" value="Closer" checked>
            <div>
              <div class="role-name">Closer</div>
              <div class="role-desc">Упаковывает итог, собирает артефакты и закрывает миссию.</div>
            </div>
            <span class="tag ok">обязателен</span>
          </label>
        </article>

        <aside class="card summary">
          <div class="box">
            <h3>Что нужно сделать дальше</h3>
            <div class="muted">1. Подключить реального COO-бота. 2. Подключить реального worker-бота. 3. Добавить их в общий Telegram-чат. 4. Проверить, что командир умеет ставить задачи, а worker — отвечать статусом, результатом или blocker.</div>
          </div>
          <div class="box">
            <h3>Минимум для реального теста</h3>
            <div class="list">
              <div>• Scout — без разведки нечего анализировать</div>
              <div>• Analyst — без него нет структуры</div>
              <div>• Writer — без него нет результата в тексте</div>
              <div>• Operator — чтобы всё не развалилось по ходу</div>
              <div>• Closer — чтобы миссия реально закрылась</div>
            </div>
          </div>
          <div class="box">
            <h3>Что сейчас происходит</h3>
            <div class="muted" id="selectedAgentsText">Сейчас это только демо-состав ролей. Следом их нужно заменить на реальных подключённых ботов.</div>
          </div>
          <button class="btn success" id="startMissionBtn">START</button>
        </aside>
      </section>
    </main>

    <script>
      const STORAGE_KEY = 'mission-control-team-v1';
      const checks = Array.from(document.querySelectorAll('.agent-check'));
      const selectedAgentsText = document.getElementById('selectedAgentsText');

      function syncSelectedText() {
        const selected = checks.filter((c) => c.checked).map((c) => c.value);
        selectedAgentsText.textContent = selected.length ? selected.join(', ') : 'Никто не выбран';
        localStorage.setItem(STORAGE_KEY, JSON.stringify(selected));
      }

      function continueToMission() {
        syncSelectedText();
        window.location.href = '/mission-control/';
      }

      document.getElementById('selectAllBtn').addEventListener('click', () => {
        checks.forEach((c) => c.checked = true);
        syncSelectedText();
      });
      document.getElementById('continueBtn').addEventListener('click', continueToMission);
      document.getElementById('startMissionBtn').addEventListener('click', continueToMission);
      checks.forEach((c) => c.addEventListener('change', syncSelectedText));

      try {
        const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null');
        if (Array.isArray(saved) && saved.length) {
          checks.forEach((c) => { c.checked = saved.includes(c.value); });
        }
      } catch {}
      syncSelectedText();
    </script>
  </body>
</html>
