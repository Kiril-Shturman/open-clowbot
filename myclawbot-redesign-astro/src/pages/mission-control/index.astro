---
---

<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Центр миссий — Командир</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=Press+Start+2P&display=swap" rel="stylesheet">
    <style>
      :root {
        --bg: #0b0d12;
        --panel: #11161f;
        --panel-2: #171d28;
        --line: rgba(255,255,255,.08);
        --text: #f5f7fb;
        --muted: #98a3b8;
        --danger: #ff5662;
        --danger-2: #ab1837;
        --ok: #63f59b;
        --warn: #ffcf57;
        --cyan: #70ddff;
        --shadow: 0 24px 80px rgba(0,0,0,.36);
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        color: var(--text);
        font-family: 'IBM Plex Sans', system-ui, sans-serif;
        background:
          radial-gradient(circle at top left, rgba(255,86,98,.18), transparent 24%),
          radial-gradient(circle at top right, rgba(112,221,255,.12), transparent 20%),
          linear-gradient(180deg, #0b0d12 0%, #080a0f 100%);
      }
      .wrap { width: min(1440px, calc(100% - 28px)); margin: 0 auto; padding: 20px 0 40px; }
      .topbar, .card {
        background: linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));
        border: 1px solid var(--line);
        border-radius: 24px;
        box-shadow: var(--shadow);
      }
      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        padding: 16px 18px;
        margin-bottom: 16px;
      }
      .brand { display: flex; gap: 14px; align-items: center; }
      .brand-mark {
        width: 54px; height: 54px; border-radius: 18px;
        background: linear-gradient(135deg, var(--danger), var(--danger-2));
        display: grid; place-items: center;
        font-family: 'Press Start 2P', monospace; font-size: 11px;
      }
      .eyebrow { font-size: 11px; letter-spacing: .08em; text-transform: uppercase; color: #ff9ea7; font-weight: 800; }
      h1 { margin: 6px 0 4px; font-size: clamp(26px, 4vw, 42px); line-height: .98; }
      .subtitle { margin: 0; color: var(--muted); max-width: 760px; }
      .actions { display: flex; gap: 10px; flex-wrap: wrap; }
      .btn {
        border: 1px solid rgba(255,255,255,.08); border-radius: 14px; padding: 12px 14px;
        background: rgba(255,255,255,.04); color: #fff; font-weight: 700; cursor: pointer;
      }
      .btn.primary { background: linear-gradient(135deg, var(--danger), var(--danger-2)); border-color: transparent; }
      .btn.warn { background: linear-gradient(135deg, #ffcc66, #b77411); border-color: transparent; color: #1b1303; }

      .hero-grid {
        display: grid;
        grid-template-columns: 1.2fr .9fr;
        gap: 16px;
        margin-bottom: 16px;
      }
      .card { padding: 18px; }
      .section-head { display: flex; justify-content: space-between; align-items: center; gap: 12px; margin-bottom: 14px; }
      .section-title { font-size: 20px; font-weight: 800; }
      .label { color: var(--muted); font-size: 13px; }
      .tag { display: inline-flex; align-items: center; gap: 6px; padding: 6px 10px; border-radius: 999px; font-size: 12px; font-weight: 700; background: rgba(255,255,255,.06); }
      .tag.live { background: rgba(99,245,155,.14); color: #c8fbd9; }
      .tag.warn { background: rgba(255,207,87,.14); color: #ffe7a6; }
      .tag.command { background: rgba(112,221,255,.14); color: #c7f2ff; }

      .mission-card {
        display: grid;
        gap: 16px;
      }
      .mission-title { font-size: clamp(28px, 4vw, 44px); font-weight: 800; line-height: .98; }
      .mission-meta { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 12px; }
      .stat {
        padding: 14px; border-radius: 18px; background: var(--panel-2); border: 1px solid rgba(255,255,255,.06);
      }
      .stat-value { font-size: 26px; font-weight: 800; margin-top: 6px; }
      .hp-wrap { padding: 14px; border-radius: 18px; background: linear-gradient(180deg, rgba(255,86,98,.10), rgba(255,255,255,.02)); border: 1px solid rgba(255,86,98,.14); }
      .hp-row { display: flex; justify-content: space-between; gap: 12px; margin-bottom: 8px; font-size: 13px; color: #ffc9ce; }
      .hp-bar { height: 16px; border-radius: 999px; overflow: hidden; background: rgba(255,255,255,.08); }
      .hp-fill { height: 100%; width: 72%; background: linear-gradient(90deg, var(--danger), #ff7f88); transition: width .6s ease; }
      .next-step {
        padding: 14px; border-radius: 18px; background: rgba(112,221,255,.08); border: 1px solid rgba(112,221,255,.12);
      }
      .next-step strong { display: block; margin-bottom: 6px; }

      .commander-panel {
        display: grid; gap: 12px;
      }
      .commander-box {
        padding: 16px; border-radius: 20px; border: 1px solid rgba(112,221,255,.16); background: linear-gradient(180deg, rgba(112,221,255,.08), rgba(255,255,255,.02));
      }
      .commander-mode { font-size: 12px; text-transform: uppercase; letter-spacing: .08em; color: #c7f2ff; font-weight: 800; }
      .commander-order { font-size: 18px; font-weight: 700; margin-top: 10px; line-height: 1.25; }
      .commander-lines { display: grid; gap: 8px; margin-top: 12px; color: var(--muted); font-size: 14px; }
      .control-buttons { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

      .mission-form {
        display: grid; grid-template-columns: 1.6fr 1fr 1fr auto; gap: 10px; align-items: end;
      }
      .field { display: grid; gap: 8px; }
      .textarea, .select {
        width: 100%; border-radius: 14px; border: 1px solid rgba(255,255,255,.08);
        background: rgba(255,255,255,.04); color: #fff; padding: 12px 14px; font: inherit;
      }
      .textarea { min-height: 98px; resize: vertical; }

      .squad-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
        margin-bottom: 16px;
      }
      .agent-card {
        padding: 16px; border-radius: 20px; background: var(--panel-2); border: 1px solid rgba(255,255,255,.06);
      }
      .agent-top { display: flex; justify-content: space-between; gap: 10px; align-items: flex-start; }
      .agent-name { font-size: 16px; font-weight: 800; }
      .agent-role { margin-top: 4px; color: var(--muted); font-size: 13px; }
      .agent-task { margin-top: 12px; font-size: 14px; line-height: 1.35; }
      .agent-zone { margin-top: 10px; color: var(--muted); font-size: 12px; }

      .lower-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 16px;
      }
      .list { display: grid; gap: 10px; }
      .item { padding: 14px; border-radius: 18px; background: var(--panel-2); border: 1px solid rgba(255,255,255,.06); }
      .item-title { font-size: 15px; font-weight: 700; }
      .item-meta { margin-top: 6px; color: var(--muted); font-size: 13px; line-height: 1.4; }

      @media (max-width: 1220px) {
        .hero-grid, .lower-grid, .squad-grid, .mission-form { grid-template-columns: 1fr; }
      }
      @media (max-width: 760px) {
        .wrap { width: min(100% - 18px, 1520px); }
        .topbar { flex-direction: column; align-items: stretch; }
        .actions { width: 100%; }
        .btn { width: 100%; }
        .mission-meta { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <main class="wrap">
      <section class="topbar">
        <div class="brand">
          <div class="brand-mark">OC</div>
          <div>
            <div class="eyebrow">Командир / миссия / отряд</div>
            <h1>Центр миссий</h1>
            <p class="subtitle">Слева — что за задача. Справа — что решил командир. Ниже — кто чем занят и что мешает двигаться дальше.</p>
          </div>
        </div>
        <div class="actions">
          <button class="btn" id="forceCheckinBtn">Проверить статусы</button>
          <button class="btn warn" id="raiseBlockerBtn">Сообщить о проблеме</button>
          <button class="btn primary" id="assignMissionBtn" style="min-width:180px;font-size:18px;padding:16px 20px;">START</button>
        </div>
      </section>

      <section class="hero-grid">
        <article class="card mission-card">
          <div class="section-head">
            <div class="section-title">1. Текущая задача</div>
            <span class="tag live" id="missionStatusValue">В работе</span>
          </div>

          <div class="mission-title" id="missionStatusSub">Контент-план на 30 дней</div>

          <div class="mission-meta">
            <div class="stat">
              <div class="label">Следующая проверка</div>
              <div class="stat-value" id="nextCheckinValue">00:28</div>
            </div>
            <div class="stat">
              <div class="label">Закрыто шагов</div>
              <div class="stat-value" id="completedTasksValue">2</div>
            </div>
            <div class="stat">
              <div class="label">Блокеры</div>
              <div class="stat-value" id="blockerCountValue">0</div>
            </div>
          </div>

          <div class="hp-wrap">
            <div class="hp-row"><span id="bossType">БОСС / МАРКЕТИНГ</span><span id="bossHpText">72 / 100</span></div>
            <div class="hp-bar"><div class="hp-fill" id="bossHpFill"></div></div>
            <div class="item-meta" style="margin-top:10px; color:#ffc9ce;">
              <div id="bossDifficulty">Сложность: эпическая</div>
              <div id="bossReward">Результат: 30 тем + рубрикатор + хуки</div>
              <div id="bossPhase">Этап: разбор → назначение → проверка → упаковка</div>
            </div>
          </div>

          <div class="next-step">
            <strong>Что делать дальше</strong>
            <div id="nextOrder">После следующей проверки командир раздаст новые подзадачи.</div>
          </div>
        </article>

        <article class="card commander-panel">
          <div class="section-head">
            <div class="section-title">2. Что решил командир</div>
            <span class="tag command" id="commanderMode">Проверяет</span>
          </div>

          <div class="commander-box">
            <div class="commander-mode">Текущий приказ</div>
            <div class="commander-order" id="currentOrder">Scout собирает источники, Analyst готовит framework, Writer ждёт input.</div>
            <div class="commander-lines">
              <div><strong>Последняя проверка:</strong> <span id="lastReview">2 мин назад</span></div>
              <div><strong>Последняя проблема:</strong> <span id="lastEscalation">Нет активных блокеров.</span></div>
            </div>
          </div>

          <div class="control-buttons">
            <button class="btn" id="reassignBtn">Переназначить задачу</button>
            <button class="btn warn" id="resolveBlockerBtn">Снять блокер</button>
          </div>

          <div class="field">
            <label class="label" for="missionInput">Новая задача</label>
            <textarea id="missionInput" class="textarea">Собери контент-план на 30 дней для продвижения OpenClaw среди предпринимателей.</textarea>
          </div>
          <div class="mission-form">
            <div class="field">
              <label class="label" for="missionType">Тип задачи</label>
              <select id="missionType" class="select">
                <option value="Маркетинг">Маркетинг</option>
                <option value="Продажи">Продажи</option>
                <option value="Исследование">Исследование</option>
                <option value="Операционка">Операционка</option>
              </select>
            </div>
            <div class="field">
              <label class="label" for="missionDifficulty">Сложность</label>
              <select id="missionDifficulty" class="select">
                <option value="Сложная">Сложная</option>
                <option value="Эпическая" selected>Эпическая</option>
                <option value="Легендарная">Легендарная</option>
              </select>
            </div>
            <div class="field">
              <label class="label">&nbsp;</label>
              <button class="btn primary" id="createMissionBtn">START</button>
            </div>
          </div>
        </article>
      </section>

      <article class="card" style="margin-bottom:16px;">
        <div class="section-head">
          <div class="section-title">3. Кто чем занят</div>
          <span class="tag">Отряд</span>
        </div>
        <div class="squad-grid" id="agentStatusList"></div>
      </article>

      <section class="lower-grid">
        <article class="card">
          <div class="section-head"><div class="section-title">Что делают агенты</div><span class="tag warn">Шаги</span></div>
          <div class="list" id="subtaskList"></div>
        </article>
        <article class="card">
          <div class="section-head"><div class="section-title">Проблемы и блокеры</div><span class="tag warn">Важно</span></div>
          <div class="list" id="blockerList"></div>
        </article>
        <article class="card">
          <div class="section-head"><div class="section-title">Что меняется по ходу миссии</div><span class="tag">Лог</span></div>
          <div class="list" id="commanderLog"></div>
        </article>
      </section>
    </main>

    <script>
      const STORAGE_KEY = 'mission-control-runtime-v3';
      const taskTemplates = {
        Маркетинг: [
          { agent: 'Scout', action: 'Собрать 12 конкурентных каналов', zone: 'Поиск', damage: 8 },
          { agent: 'Analyst', action: 'Выделить паттерны форматов', zone: 'Анализ', damage: 10 },
          { agent: 'Writer', action: 'Собрать 15 заголовков', zone: 'Тексты', damage: 9 },
          { agent: 'Operator', action: 'Разложить календарь публикаций', zone: 'Контроль', damage: 7 },
          { agent: 'Closer', action: 'Упаковать финальный план', zone: 'Финал', damage: 12 },
        ],
        Продажи: [
          { agent: 'Scout', action: 'Поднять 50 потенциальных лидов', zone: 'Поиск', damage: 9 },
          { agent: 'Analyst', action: 'Квалифицировать сегменты', zone: 'Анализ', damage: 8 },
          { agent: 'Writer', action: 'Подготовить outreach-сообщения', zone: 'Тексты', damage: 8 },
          { agent: 'Operator', action: 'Распределить лидов по приоритету', zone: 'Контроль', damage: 6 },
          { agent: 'Closer', action: 'Собрать базу к выдаче', zone: 'Финал', damage: 12 },
        ],
        Исследование: [
          { agent: 'Scout', action: 'Собрать 10 источников', zone: 'Поиск', damage: 8 },
          { agent: 'Analyst', action: 'Построить таблицу сравнений', zone: 'Анализ', damage: 10 },
          { agent: 'Writer', action: 'Написать summary и выводы', zone: 'Тексты', damage: 8 },
          { agent: 'Operator', action: 'Синхронизировать findings', zone: 'Контроль', damage: 6 },
          { agent: 'Closer', action: 'Собрать финальный отчёт', zone: 'Финал', damage: 12 },
        ],
        Операционка: [
          { agent: 'Scout', action: 'Собрать входные условия', zone: 'Поиск', damage: 6 },
          { agent: 'Analyst', action: 'Выявить узкие места', zone: 'Анализ', damage: 8 },
          { agent: 'Writer', action: 'Собрать SOP', zone: 'Тексты', damage: 7 },
          { agent: 'Operator', action: 'Маршрутизировать процессы', zone: 'Контроль', damage: 10 },
          { agent: 'Closer', action: 'Упаковать операционный набор', zone: 'Финал', damage: 11 },
        ],
      };

      const defaultState = {
        mission: {
          title: 'Контент-план на 30 дней',
          type: 'Маркетинг',
          difficulty: 'Эпическая',
          reward: '30 тем + рубрикатор + хуки',
          hp: 72,
          maxHp: 100,
          phase: 'Разбор → назначение → проверка → упаковка',
          active: true,
        },
        commander: {
          mode: 'Проверяет',
          currentOrder: 'Scout собирает источники, Analyst готовит framework, Writer ждёт input.',
          lastReview: '2 мин назад',
          nextOrder: 'После следующей проверки выдать следующий шаг Writer.',
          lastEscalation: 'Нет активных блокеров.',
          secondsToCheckin: 28,
        },
        completedTasks: 2,
        subtasks: [
          { id: 1, agent: 'Scout', text: 'Собрать 12 каналов', status: 'сделано' },
          { id: 2, agent: 'Analyst', text: 'Выделить 6 паттернов', status: 'сделано' },
          { id: 3, agent: 'Writer', text: 'Собрать 15 заголовков', status: 'активно' },
          { id: 4, agent: 'Operator', text: 'Собрать publishing map', status: 'в очереди' },
          { id: 5, agent: 'Closer', text: 'Подготовить итоговую выдачу', status: 'в очереди' },
        ],
        blockers: [],
        agents: [
          { name: 'Scout', role: 'Поиск', status: 'Работает в поле', task: 'Собирает источники', zone: 'Поиск' },
          { name: 'Analyst', role: 'Анализ', status: 'Готовит структуру', task: 'Выделяет паттерны', zone: 'Анализ' },
          { name: 'Writer', role: 'Тексты', status: 'Активный исполнитель', task: 'Готовит заголовки', zone: 'Тексты' },
          { name: 'Operator', role: 'Контроль', status: 'Ждёт очередь', task: 'Ожидает приказ', zone: 'Контроль' },
          { name: 'Closer', role: 'Финал', status: 'Ждёт завершения', task: 'Ожидает финал', zone: 'Финал' },
        ],
        commanderLog: [
          'Командир принял миссию и разбил её на стартовые шаги.',
          'Scout и Analyst уже закрыли первые этапы.',
          'Writer сейчас главный активный агент.',
        ],
      };

      let state = loadState();
      const $ = (id) => document.getElementById(id);
      const humanTime = (sec) => `00:${String(Math.max(sec, 0)).padStart(2, '0')}`;
      const rand = (arr) => arr[Math.floor(Math.random() * arr.length)];
      const blockerReasons = ['не хватает данных', 'нужен input от человека', 'нет подтверждения', 'источник не найден'];

      function loadState() {
        try {
          const raw = localStorage.getItem(STORAGE_KEY);
          return raw ? { ...defaultState, ...JSON.parse(raw) } : structuredClone(defaultState);
        } catch {
          return structuredClone(defaultState);
        }
      }
      function saveState() { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); }
      function pushLog(text) { state.commanderLog.unshift(text); state.commanderLog = state.commanderLog.slice(0, 10); }

      function renderSummary() {
        $('missionStatusValue').textContent = state.mission.active ? 'В работе' : 'Готово';
        $('missionStatusSub').textContent = state.mission.title;
        $('nextCheckinValue').textContent = humanTime(state.commander.secondsToCheckin);
        $('completedTasksValue').textContent = String(state.completedTasks);
        $('blockerCountValue').textContent = String(state.blockers.length);
      }
      function renderMission() {
        $('bossType').textContent = `БОСС / ${state.mission.type.toUpperCase()}`;
        $('bossHpText').textContent = `${state.mission.hp} / ${state.mission.maxHp}`;
        $('bossHpFill').style.width = `${(state.mission.hp / state.mission.maxHp) * 100}%`;
        $('bossDifficulty').textContent = `Сложность: ${state.mission.difficulty}`;
        $('bossReward').textContent = `Результат: ${state.mission.reward}`;
        $('bossPhase').textContent = `Этап: ${state.mission.phase}`;
        $('commanderMode').textContent = state.commander.mode;
        $('currentOrder').textContent = state.commander.currentOrder;
        $('lastReview').textContent = state.commander.lastReview;
        $('lastEscalation').textContent = state.commander.lastEscalation;
        $('nextOrder').textContent = state.commander.nextOrder;
      }
      function renderAgents() {
        $('agentStatusList').innerHTML = state.agents.map((agent) => `
          <div class="agent-card">
            <div class="agent-top">
              <div>
                <div class="agent-name">${agent.name}</div>
                <div class="agent-role">${agent.role}</div>
              </div>
              <span class="tag ${agent.status.includes('Жд') ? '' : 'live'}">${agent.zone}</span>
            </div>
            <div class="agent-task">${agent.task}</div>
            <div class="agent-zone">Статус: ${agent.status}</div>
          </div>
        `).join('');
      }
      function renderSubtasks() {
        $('subtaskList').innerHTML = state.subtasks.map((task) => `
          <div class="item">
            <div class="item-title">${task.text}</div>
            <div class="item-meta">${task.agent} • ${task.status}</div>
          </div>
        `).join('');
      }
      function renderBlockers() {
        $('blockerList').innerHTML = state.blockers.length
          ? state.blockers.map((b) => `<div class="item"><div class="item-title">${b.agent}</div><div class="item-meta">${b.reason}</div></div>`).join('')
          : '<div class="item"><div class="item-title">Сейчас проблем нет</div><div class="item-meta">Миссия идёт без блокеров</div></div>';
      }
      function renderLog() {
        $('commanderLog').innerHTML = state.commanderLog.map((line) => `<div class="item"><div class="item-title">${line}</div></div>`).join('');
      }
      function renderAll() {
        renderSummary();
        renderMission();
        renderAgents();
        renderSubtasks();
        renderBlockers();
        renderLog();
        saveState();
      }

      function createMission() {
        const title = $('missionInput').value.trim() || 'Новая миссия';
        const type = $('missionType').value;
        const difficulty = $('missionDifficulty').value;
        const reward = type === 'Продажи' ? 'Лиды + контакты' : type === 'Исследование' ? 'Сводка + таблица' : type === 'Операционка' ? 'SOP + процессы' : 'Контент + хуки + план';
        const template = taskTemplates[type] || taskTemplates['Маркетинг'];
        state.mission = { title, type, difficulty, reward, hp: 100, maxHp: 100, phase: 'Разбор → назначение → проверка → упаковка', active: true };
        state.commander = {
          mode: 'Назначает',
          currentOrder: `Командир принял задачу «${title}» и раздаёт стартовые шаги.`,
          lastReview: 'только что',
          nextOrder: 'После проверки двинуть следующего агента.',
          lastEscalation: 'Нет активных блокеров.',
          secondsToCheckin: 30,
        };
        state.subtasks = template.map((t, i) => ({ id: i + 1, agent: t.agent, text: t.action, status: i === 0 ? 'активно' : 'в очереди' }));
        state.completedTasks = 0;
        state.blockers = [];
        state.agents = [
          { name: 'Scout', role: 'Поиск', status: 'Ждёт приказ', task: 'Ожидает', zone: 'Поиск' },
          { name: 'Analyst', role: 'Анализ', status: 'Ждёт приказ', task: 'Ожидает', zone: 'Анализ' },
          { name: 'Writer', role: 'Тексты', status: 'Ждёт приказ', task: 'Ожидает', zone: 'Тексты' },
          { name: 'Operator', role: 'Контроль', status: 'Ждёт приказ', task: 'Ожидает', zone: 'Контроль' },
          { name: 'Closer', role: 'Финал', status: 'Ждёт приказ', task: 'Ожидает', zone: 'Финал' },
        ];
        const first = state.subtasks[0];
        const firstAgent = state.agents.find((a) => a.name === first.agent);
        if (firstAgent) {
          firstAgent.status = 'Активный исполнитель';
          firstAgent.task = first.text;
        }
        state.commanderLog = [`Командир создал новую миссию: ${title}.`];
        renderAll();
      }

      function raiseBlocker() {
        const activeAgent = rand(state.agents.filter((a) => a.status.includes('Актив')) || state.agents);
        const blocker = { agent: activeAgent.name, reason: rand(blockerReasons) };
        state.blockers.unshift(blocker);
        state.blockers = state.blockers.slice(0, 5);
        state.commander.mode = 'Эскалация';
        state.commander.lastEscalation = `${blocker.agent}: ${blocker.reason}`;
        activeAgent.status = 'Застрял';
        activeAgent.task = blocker.reason;
        pushLog(`Командир получил проблему от ${blocker.agent}: ${blocker.reason}.`);
        renderAll();
      }

      function resolveBlocker() {
        if (!state.blockers.length) return;
        const blocker = state.blockers.shift();
        const agent = state.agents.find((a) => a.name === blocker.agent);
        if (agent) {
          agent.status = 'Вернулся в работу';
          agent.task = 'Продолжает этап';
        }
        state.commander.mode = 'Переназначает';
        state.commander.lastEscalation = `Решён blocker: ${blocker.agent}`;
        pushLog(`Командир снял проблему у ${blocker.agent}.`);
        renderAll();
      }

      function reassignTask() {
        const queued = state.subtasks.find((t) => t.status === 'в очереди');
        if (!queued) return;
        const target = rand(state.agents.filter((a) => a.name !== queued.agent));
        queued.agent = target.name;
        target.status = 'Получил переназначение';
        target.task = queued.text;
        state.commander.currentOrder = `${target.name} забирает шаг: ${queued.text}`;
        pushLog(`Командир переназначил задачу на ${target.name}.`);
        renderAll();
      }

      function runCheckin() {
        if (!state.mission.active) return;
        state.commander.mode = 'Проверяет';
        state.commander.lastReview = 'только что';
        state.commander.secondsToCheckin = 30;

        if (state.blockers.length) {
          state.commander.currentOrder = 'Сначала закрыть проблему, потом продолжать миссию.';
          state.commander.nextOrder = 'Снять blocker и вернуть агента в работу.';
          pushLog('Командир остановил прогресс из-за активной проблемы.');
          renderAll();
          return;
        }

        const active = state.subtasks.find((t) => t.status === 'активно');
        if (!active) return;
        active.status = 'сделано';
        state.completedTasks += 1;
        const damage = rand([7, 8, 9, 10, 12]);
        state.mission.hp = Math.max(0, state.mission.hp - damage);
        const activeAgent = state.agents.find((a) => a.name === active.agent);
        if (activeAgent) {
          activeAgent.status = 'Завершил этап';
          activeAgent.task = `Сделал: ${active.text}`;
        }
        pushLog(`${active.agent} закрыл шаг «${active.text}» → Boss HP -${damage}.`);

        const next = state.subtasks.find((t) => t.status === 'в очереди');
        if (next) {
          next.status = 'активно';
          const nextAgent = state.agents.find((a) => a.name === next.agent);
          if (nextAgent) {
            nextAgent.status = 'Активный исполнитель';
            nextAgent.task = next.text;
          }
          state.commander.currentOrder = `${next.agent} получает следующий шаг: ${next.text}`;
          state.commander.nextOrder = 'После следующей проверки двинуть миссию дальше.';
        } else {
          state.mission.active = false;
          state.commander.mode = 'Миссия завершена';
          state.commander.currentOrder = 'Все шаги закрыты. Миссия завершена.';
          state.commander.nextOrder = 'Можно ставить следующую задачу.';
          pushLog(`Командир закрыл миссию «${state.mission.title}».`);
        }
        renderAll();
      }

      function tickTimer() {
        if (state.commander.secondsToCheckin > 0 && state.mission.active) {
          state.commander.secondsToCheckin -= 1;
          renderSummary();
          saveState();
          return;
        }
        if (state.mission.active) runCheckin();
      }

      $('createMissionBtn').addEventListener('click', createMission);
      $('assignMissionBtn').addEventListener('click', createMission);
      $('forceCheckinBtn').addEventListener('click', runCheckin);
      $('raiseBlockerBtn').addEventListener('click', raiseBlocker);
      $('resolveBlockerBtn').addEventListener('click', resolveBlocker);
      $('reassignBtn').addEventListener('click', reassignTask);

      renderAll();
      setInterval(tickTimer, 1000);
    </script>
  </body>
</html>
